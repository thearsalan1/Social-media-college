{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "./",
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": ["./**/*.ts", "./**/*.d.ts", "test.csv", "src"],
  "exclude": ["node_modules", "dist"]
}
